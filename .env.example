# ── Base de datos ──────────────────────────────────────────────────────────
# Formato: Host=host;Port=5432;Database=db;Username=user;Password=pass
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=Host=db;Port=5432;Database=eventmanager;Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD}

# ── JWT ────────────────────────────────────────────────────────────────────
JWT__Secret=CAMBIA_ESTE_SECRETO_POR_UNO_DE_AL_MENOS_32_CARACTERES
JWT__Issuer=EventManagerAPI
JWT__Audience=EventManagerClients
JWT__ExpiryMinutes=60

# ── ASP.NET Core ───────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
