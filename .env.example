# ── Base de datos ──────────────────────────────────────────────────────────
# Formato: Host=host;Port=5432;Database=db;Username=user;Password=pass
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=Host=db;Port=5432;Database=eventmanager;Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD}

# ── JWT ────────────────────────────────────────────────────────────────────
JWT__Secret=CAMBIA_ESTE_SECRETO_POR_UNO_DE_AL_MENOS_32_CARACTERES
JWT__Issuer=EventManagerAPI
JWT__Audience=EventManagerClients
JWT__ExpiryMinutes=60

# ── SMTP (correo saliente) ─────────────────────────────────────────────────
# Para desarrollo local se recomienda Mailtrap (https://mailtrap.io)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USE_SSL=false
SMTP_USER=tu_usuario_mailtrap
SMTP_PASS=tu_password_mailtrap
SMTP_FROM_ADDRESS=no-reply@eventmanager.com
SMTP_FROM_NAME=EventManager

# Equivalentes en formato de sección ASP.NET Core (doble guion bajo = anidamiento)
Smtp__Host=sandbox.smtp.mailtrap.io
Smtp__Port=587
Smtp__UseSsl=false
Smtp__Username=tu_usuario_mailtrap
Smtp__Password=tu_password_mailtrap
Smtp__FromAddress=no-reply@eventmanager.com
Smtp__FromName=EventManager

# ── ASP.NET Core ───────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
